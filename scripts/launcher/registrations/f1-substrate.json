{
  "schema_version": "1.0.0",
  "id": "f1-substrate",
  "bead_prefix": "f1",
  "display_name": "F1 telemetry substrate (FastF1→DuckDB→FastAPI)",
  "repo": {
    "url": "https://github.com/ojfbot/f1-substrate",
    "local_path": "${HOME}/ojfbot/f1-substrate",
    "branch": "main"
  },
  "priority_tier": "active",
  "rig_profile": "non-frame",
  "order": 50,
  "tags": ["f1", "data", "python", "fastapi"],
  "panes": [
    {
      "name": "substrate",
      "command": ".venv/bin/uvicorn f1_substrate.api:app --port 8781 || (echo 'substrate dev unavailable; idle' && tail -f /dev/null)",
      "size": "60%",
      "ready_signal": {
        "type": "stdout_match",
        "pattern": "Application startup complete",
        "timeout_seconds": 60
      }
    },
    {
      "name": "claude-headless",
      "command": "node ${HOME}/ojfbot/core/scripts/hooks/bead-emit.mjs agent-create --role=worker --app=f1-substrate --session-id=launcher && echo '✓ f1-substrate-agent-worker registered' && tail -f /dev/null",
      "size": "40%",
      "split": "horizontal"
    }
  ],
  "claude_sessions": {
    "headless": { "enabled": true, "role": "worker" },
    "interactive": { "key_binding": "M-6" }
  }
}
