{
  "schema_version": "1.0.0",
  "id": "gastown-pilot",
  "bead_prefix": "gt",
  "display_name": "gastown-pilot dashboard",
  "repo": {
    "url": "https://github.com/ojfbot/gastown-pilot",
    "local_path": "/Users/yuri/ojfbot/gastown-pilot",
    "branch": "main"
  },
  "priority_tier": "active",
  "rig_profile": "frame",
  "order": 30,
  "tags": ["frontend", "dashboard", "MF-remote"],
  "panes": [
    {
      "name": "dev",
      "command": "pnpm --filter @ojfbot/gastown-pilot-browser-app dev",
      "size": "60%",
      "ready_signal": {
        "type": "stdout_match",
        "pattern": "Local:.*http://localhost:3017",
        "timeout_seconds": 90
      }
    },
    {
      "name": "claude-headless",
      "command": "node /Users/yuri/ojfbot/core/scripts/hooks/bead-emit.mjs agent-create --role=worker --app=gastown-pilot --session-id=launcher && echo '✓ gastown-pilot-agent-worker registered' && tail -f /dev/null",
      "size": "20%",
      "split": "horizontal"
    },
    {
      "name": "tests",
      "command": "pnpm test:watch || tail -f /dev/null",
      "size": "20%",
      "split": "vertical"
    }
  ],
  "claude_sessions": {
    "headless": { "enabled": true, "role": "worker" },
    "interactive": { "key_binding": "M-4" }
  }
}
